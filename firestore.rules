rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if requesting user is a teacher
    // FIXED: Safely check if user document exists and has role field
    function isTeacher() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'teacher';
    }

    // Helper function to check if requesting user is a parent
    // FIXED: Safely check if user document exists and has role field
    function isParent() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'parent';
    }

    match /users/{userId} {
      // Allow users to read/write their own user document
      // Allow all authenticated users to read user documents (for teacher search)
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Learning reports subcollection
      match /learningReports/{reportId} {
        // Allow authenticated users to create reports in their own subcollection
        allow create: if request.auth != null && request.auth.uid == userId;
        
        // Allow users to read their own reports
        // Also allow teachers and parents to read student reports
        // Note: Connection verification is enforced in application code since
        // Firestore security rules cannot query collections to verify connections
        allow read: if request.auth != null && 
                    (request.auth.uid == userId || isTeacher() || isParent());
        
        // Allow users to update their own reports (if needed in the future)
        allow update: if request.auth != null && request.auth.uid == userId;
        
          // Allow users to delete their own reports (if needed in the future)
          allow delete: if request.auth != null && request.auth.uid == userId;
        }
        
        // Persistent learning profile subcollection
        match /learningProfile/{profileId} {
          // Allow users to read/write their own learning profile
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

    // Message requests - allows users to request permission to message each other
    match /messageRequests/{requestId} {
      // Users can create requests where they are the requestor
      allow create: if request.auth != null && 
                    request.auth.uid == request.resource.data.requestorId;
      
      // Users can read requests where they are either the requestor or requested
      allow read: if request.auth != null && 
                  (request.auth.uid == resource.data.requestorId || 
                   request.auth.uid == resource.data.requestedId);
      
      // Only the requested user can update (accept/reject) the request
      allow update: if request.auth != null && 
                    request.auth.uid == resource.data.requestedId &&
                    request.resource.data.status in ['accepted', 'rejected'];
      
      // Users can delete their own outgoing requests
      allow delete: if request.auth != null && 
                    request.auth.uid == resource.data.requestorId;
    }

    // Message permissions - bidirectional permissions for messaging
    match /messagePermissions/{permissionId} {
      // Users can create permissions (typically when accepting a request)
      allow create: if request.auth != null && 
                    (request.auth.uid == request.resource.data.userId1 || 
                     request.auth.uid == request.resource.data.userId2);
      
      // Users can read permissions where they are involved
      allow read: if request.auth != null && 
                  (request.auth.uid == resource.data.userId1 || 
                   request.auth.uid == resource.data.userId2);
      
      // Users can delete permissions where they are involved
      allow delete: if request.auth != null && 
                    (request.auth.uid == resource.data.userId1 || 
                     request.auth.uid == resource.data.userId2);
    }

    // Messages collection
    match /messages/{messageId} {
      // Users can create messages where they are the sender
      allow create: if request.auth != null && 
                    request.auth.uid == request.resource.data.senderId;
      
      // Users can read messages where they are either sender or receiver
      allow read: if request.auth != null && 
                  (request.auth.uid == resource.data.senderId || 
                   request.auth.uid == resource.data.receiverId);
      
      // Users can update messages where they are:
      // - Receiver (to mark as read)
      // - Sender (to edit their own message within time limit)
      // - Either sender or receiver (to add/update transcript)
      allow update: if request.auth != null && 
                    (request.auth.uid == resource.data.receiverId ||
                     (request.auth.uid == resource.data.senderId && 
                      request.resource.data.edited == true &&
                      request.resource.data.editedAt != null) ||
                     // Allow adding/updating transcript by either sender or receiver
                     ((request.auth.uid == resource.data.senderId || 
                       request.auth.uid == resource.data.receiverId) &&
                      request.resource.data.keys().hasAll(['transcript']) &&
                      request.resource.data.transcript is string));
      
    // Users can delete their own sent messages
    allow delete: if request.auth != null && 
                  request.auth.uid == resource.data.senderId;
    }

    // Typing status - users can set/clear their own typing status
    match /typingStatus/{typingId} {
      // Users can create/update their own typing status
      allow create, update: if request.auth != null &&
                            request.resource.data.userId == request.auth.uid;
      
      // Users can read typing status where they're part of the conversation
      // (the userId should be the other user in the conversation)
      allow read: if request.auth != null &&
                  (resource.data.userId != request.auth.uid);
      
      // Users can delete their own typing status
      allow delete: if request.auth != null &&
                    resource.data.userId == request.auth.uid;
    }

    // Teacher-Student connection requests
    match /connectionRequests/{requestId} {
      // Students can create requests to teachers
      // Teachers can create requests to students
      allow create: if request.auth != null &&
                    (request.resource.data.requestorId == request.auth.uid ||
                     request.resource.data.requestedId == request.auth.uid);
      
      // Users can read requests where they are the requestor or requested
      allow read: if request.auth != null &&
                  (resource.data.requestorId == request.auth.uid ||
                   resource.data.requestedId == request.auth.uid);
      
      // Only the requested party (teacher or student) can update (accept/reject)
      allow update: if request.auth != null &&
                    resource.data.requestedId == request.auth.uid;
      
      // Users can delete their own requests
      allow delete: if request.auth != null &&
                    (resource.data.requestorId == request.auth.uid ||
                     resource.data.requestedId == request.auth.uid);
    }

    // Teacher-Student connections (confirmed)
    match /connections/{connectionId} {
      // Users can create connections when both parties agree
      allow create: if request.auth != null &&
                    (request.resource.data.studentId == request.auth.uid ||
                     request.resource.data.teacherId == request.auth.uid);
      
      // Users can read connections where they are the student or teacher
      allow read: if request.auth != null &&
                  (resource.data.studentId == request.auth.uid ||
                   resource.data.teacherId == request.auth.uid);
      
      // No updates allowed (connections are permanent)
      allow update: if false;
      
      // Either party can delete the connection
      allow delete: if request.auth != null &&
                    (resource.data.studentId == request.auth.uid ||
                     resource.data.teacherId == request.auth.uid);
    }

    // Parent-Student connection requests
    match /parentConnectionRequests/{requestId} {
      // Parents can create requests to students
      // Students can create requests to parents
      allow create: if request.auth != null &&
                    (request.resource.data.requestorId == request.auth.uid ||
                     request.resource.data.requestedId == request.auth.uid);
      
      // Users can read requests where they are the requestor or requested
      allow read: if request.auth != null &&
                  (resource.data.requestorId == request.auth.uid ||
                   resource.data.requestedId == request.auth.uid);
      
      // Only the requested party (parent or student) can update (accept/reject)
      allow update: if request.auth != null &&
                    resource.data.requestedId == request.auth.uid;
      
      // Users can delete their own requests
      allow delete: if request.auth != null &&
                    (resource.data.requestorId == request.auth.uid ||
                     resource.data.requestedId == request.auth.uid);
    }

    // Parent-Student connections (confirmed)
    match /parentConnections/{connectionId} {
      // Users can create connections when both parties agree
      allow create: if request.auth != null &&
                    (request.resource.data.studentId == request.auth.uid ||
                     request.resource.data.parentId == request.auth.uid);
      
      // Users can read connections where they are the student or parent
      allow read: if request.auth != null &&
                  (resource.data.studentId == request.auth.uid ||
                   resource.data.parentId == request.auth.uid);
      
      // No updates allowed (connections are permanent)
      allow update: if false;
      
      // Either party can delete the connection
      allow delete: if request.auth != null &&
                    (resource.data.studentId == request.auth.uid ||
                     resource.data.parentId == request.auth.uid);
    }

    // MCQ Sets collection
    match /mcqSets/{mcqSetId} {
      // Teachers can create MCQ sets (must be the owner)
      allow create: if request.auth != null && 
                    isTeacher() && 
                    request.resource.data.userId == request.auth.uid;
      
      // Teachers can read their own MCQ sets
      // Students can read MCQ sets that are assigned to them (via assignments)
      // For now, allow authenticated users to read (assignment validation happens in app code)
      allow read: if request.auth != null;
      
      // Teachers can update/delete their own MCQ sets
      allow update, delete: if request.auth != null && 
                            isTeacher() && 
                            resource.data.userId == request.auth.uid;
    }

    // Assignments collection
    match /assignments/{assignmentId} {
      // Teachers can create assignments
      allow create: if request.auth != null && 
                    isTeacher() && 
                    request.resource.data.teacherId == request.auth.uid;
      
      // Teachers can read their own assignments
      // Students can read assignments (validation happens in app code)
      // Note: Firestore rules don't easily support array membership checks,
      // so we allow authenticated users to read and validate in app code
      allow read: if request.auth != null;
      
      // Only the teacher who created the assignment can update it
      allow update: if request.auth != null && 
                    isTeacher() && 
                    resource.data.teacherId == request.auth.uid;
      
      // Only the teacher who created the assignment can delete it
      allow delete: if request.auth != null && 
                    isTeacher() && 
                    resource.data.teacherId == request.auth.uid;
    }

    // Submissions collection
    match /submissions/{submissionId} {
      // Students can create their own submissions
      allow create: if request.auth != null && 
                    request.resource.data.studentId == request.auth.uid;
      
      // Students can read their own submissions
      // Teachers can read submissions for their assignments
      allow read: if request.auth != null && 
                  (resource.data.studentId == request.auth.uid ||
                   (isTeacher() && resource.data.teacherId == request.auth.uid));
      
      // Students cannot update submissions after creation (immutable)
      // Teachers can update to add feedback/comments in the future
      allow update: if request.auth != null && 
                    isTeacher() && 
                    resource.data.teacherId == request.auth.uid;
      
      // Only teachers can delete submissions (for moderation)
      allow delete: if request.auth != null && 
                    isTeacher() && 
                    resource.data.teacherId == request.auth.uid;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // System/teachers can create notifications (handled in app code)
      allow create: if request.auth != null;
      
      // Users can only read their own notifications
      allow read: if request.auth != null && 
                  resource.data.userId == request.auth.uid;
      
      // Users can update their own notifications (e.g., mark as read)
      allow update: if request.auth != null && 
                    resource.data.userId == request.auth.uid &&
                    // Only allow updating isRead and readAt fields
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['isRead', 'readAt']);
      
      // Users can delete their own notifications
      allow delete: if request.auth != null && 
                    resource.data.userId == request.auth.uid;
    }

    match /{document=**} { 
      allow read, write: if false; 
    }
  }
}

